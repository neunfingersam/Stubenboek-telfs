# ============================================================
# Haus Stubenboeck – Required Environment Variables
# Copy this file to .env.local for local development.
# ============================================================

# Database
# Local SQLite file – works for development and demos.
# NOTE: Vercel's serverless functions run on a read-only Lambda filesystem,
# so a local SQLite file does NOT persist between requests or deployments.
# For production, switch to a managed SQLite service (e.g. Turso / libSQL)
# or a serverless Postgres provider (e.g. Neon) and update DATABASE_URL
# and the Prisma adapter accordingly.
DATABASE_URL="file:./dev.db"

# Resend – transactional email (https://resend.com)
RESEND_API_KEY="re_your_api_key_here"

# Email address that receives booking-request notifications and
# admin confirm/reject links.
ADMIN_EMAIL="info@stubenboeck-telfs.com"

# Public base URL used to build absolute links in emails and meta tags.
# Set this to your Vercel deployment URL or custom domain.
NEXT_PUBLIC_BASE_URL="https://your-vercel-domain.vercel.app"
